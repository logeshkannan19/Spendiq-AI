## Next / App
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Supabase (project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

## Server-only Supabase (service role for automation + webhooks)
SUPABASE_SERVICE_ROLE_KEY=

## OpenAI
OPENAI_API_KEY=

## WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

## Optional: route inbound WhatsApp to n8n (recommended)
N8N_EXPENSE_WEBHOOK_URL=

## Optional: protect automation endpoints (n8n cron)
AUTOMATION_TOKEN=change-me-too

