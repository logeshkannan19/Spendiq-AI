            { "name": "Authorization", "value": "Bearer {{$env.WHATSAPP_ACCESS_TOKEN}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": $json.from,\n  \"type\": \"text\",\n  \"text\": {\"body\": \"✅ Logged your expense. Ask: How much did I spend this month? 📊\"}\n}"
      },
      "id": "WhatsAppReply",
      "name": "WhatsApp — reply",
